{
  "rewrites": [
    {
      "source": "/action-plan/:path*",
      "destination": "https://sauragency.com/action-plan/:path*"
    },
    {
      "source": "/photos/:path*",
      "destination": "https://sauragency.com/photos/:path*"
    },
    {
      "source": "/logos/:path*",
      "destination": "https://sauragency.com/logos/:path*"
    },
    {
      "source": "/fonts/:path*",
      "destination": "https://sauragency.com/fonts/:path*"
    },
    {
      "source": "/_next/image",
      "destination": "https://sauragency.com/_next/image"
    }
  ]
}
